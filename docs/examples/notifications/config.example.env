# OpenCode Secure Notifications — Configuration Example
# Copy to .env.notifications and replace placeholder values.
# NEVER commit real credentials to version control.

# ── Email (SMTP) ──
SMTP_HOST=<REPLACE_ME>
SMTP_PORT=587
SMTP_USERNAME=<REPLACE_ME>
SMTP_PASSWORD=<REPLACE_ME>
SMTP_FROM=<REPLACE_ME>
SMTP_RECIPIENT_ALLOWLIST=<REPLACE_ME>

# ── Telegram (optional) ──
TELEGRAM_BOT_TOKEN=<OPTIONAL_REPLACE_ME>
TELEGRAM_CHAT_ID=<OPTIONAL_REPLACE_ME>

# ── Webhook (optional) ──
WEBHOOK_URL=<OPTIONAL_REPLACE_ME>
WEBHOOK_HMAC_SECRET=<OPTIONAL_REPLACE_ME>

# ── Queue ──
# NOTIFICATION_DB_PATH=data/notifications.db
