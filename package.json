{
  "name": "akm-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Controlled AKM v0.8.1 adapter — OpenCode MCP tools + local HTTP API",
  "scripts": {
    "build": "tsc",
    "start": "node dist/mcp-server.js",
    "start:http": "node dist/http-server.js",
    "dev:mcp": "tsx src/mcp-server.ts",
    "dev:http": "tsx src/http-server.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:injection": "bash tests/run-injection-tests.sh",
    "lint": "tsc --noEmit",
    "lint:ci": "tsc --noEmit --project tsconfig.ci.json",
    "validate:docs": "tsx scripts/validate-docs.ts",
    "test:jest": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:vitest": "node node_modules/.bin/vitest run",
    "test:bun": "/root/.bun/bin/bun test tests/notifications.test.ts tests/safe-recovery.test.ts",
    "test:all": "node --experimental-vm-modules node_modules/.bin/jest --forceExit && npx vitest run && bun test tests/notifications.test.ts tests/safe-recovery.test.ts",
    "test:matrix": "tsx scripts/run-test-matrix.ts",
    "test:mcp-contract": "node --experimental-vm-modules node_modules/.bin/jest --testPathPatterns=mcp-contract --forceExit",
    "test:observability": "node --experimental-vm-modules node_modules/.bin/jest --testPathPatterns=observability --forceExit",
    "check:mcp-health": "tsx scripts/check-mcp-health.ts",
    "observability:report": "tsx scripts/opencode-observability-report.ts"
  },
  "dependencies": {
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.20",
    "@types/nodemailer": "^8.0.0",
    "bun-types": "^1.3.14",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
